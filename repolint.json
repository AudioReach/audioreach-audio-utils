{
  "extends": "https://raw.githubusercontent.com/todogroup/repolinter/master/rulesets/schema.json",
  "rules": {
    "source-license-headers-exist": {
      "level": "error",
      "rule": {
        "type": "file-starts-with",
        "options": {
          "globsAll": [
            "**/*.py",
            "**/*.js",
            "**/*.c",
            "**/*.cc",
            "**/*.cpp",
            "**/*.h",
            "**/*.ts",
            "**/*.sh",
            "**/*.rs",
            "**/*.java",
            "**/*.go",
            "**/*.bbclass",
            "**/*.S"
          ],
          "skip-paths-matching": {
            "patterns": [
              "audio-route\/include\/audio_route\/audio_route.h"
            ]
          },
          "lineCount": 60,
          "flags": "i"
        }
      }
    }
  }
}
